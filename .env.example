# ⚡ CORE (Required)
DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
NEXTAUTH_SECRET=generate_a_secure_random_string
RESEND_API_KEY=re_your_resend_key
NEXT_PUBLIC_BASE_URL=http://localhost:3000

